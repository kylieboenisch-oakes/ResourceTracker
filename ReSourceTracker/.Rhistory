poverty_fill_scale <- scale_fill_viridis_d(
option = "C",
end    = 0.9,
name   = "% Below Poverty Line"
)
# Compact plot builder so styling stays consistent
# Labels (median %WW + n) are placed INSIDE each box by default,
# but selected bins can have labels ABOVE the box in black.
make_pov_plot <- function(df, main_title, subtitle = NULL, outside_bins = NULL) {
df_ord <- df %>% order_bins_local()
# identify highest-poverty bin (last factor level)
highest_bin <- tail(levels(df_ord$var_bin), 1)
# per-bin summaries for labels
lab_df <- df_ord %>%
group_by(var_bin) %>%
summarise(
n   = n(),
med = median(metric_value, na.rm = TRUE),
q1  = quantile(metric_value, 0.25, na.rm = TRUE),
q3  = quantile(metric_value, 0.75, na.rm = TRUE),
.groups = "drop"
) %>%
mutate(
height      = q3 - q1,
is_highest  = var_bin == highest_bin,
is_outside  = if (!is.null(outside_bins)) var_bin %in% outside_bins else FALSE,
# default position: ~75% of the way up the box
y_pos_default = case_when(
is.finite(height) & height > 0 ~ q1 + 0.55 * height,
TRUE                            ~ med
),
# for the yellow/highest bin, push label closer to the top of box
y_pos_highest = case_when(
is_highest & is.finite(height) & height > 0 ~ q1 + 0.90 * height,
TRUE                                        ~ y_pos_default
),
# for "outside" bins, place label just above the box
y_pos_outside = case_when(
is.finite(q3) ~ pmin(100, q3 + 12),         # a bit above upper whisker/IQR
TRUE         ~ pmin(100, med + 12)
),
# final y position
y_pos = case_when(
is_outside            ~ y_pos_outside,
!is_outside & is_highest ~ y_pos_highest,
TRUE                  ~ y_pos_default
),
label_colour = ifelse(is_outside, "black", "white"),
label = paste0("Median: ", round(med, 1), "%\n(n = ", n, ")")
)
ggplot(df_ord, aes(x = var_bin, y = metric_value, fill = var_bin)) +
geom_boxplot(outlier.alpha = 0.4) +
geom_text(
data       = lab_df,
aes(x = var_bin, y = y_pos, label = label, colour = label_colour),
inherit.aes = FALSE,
size       = 2.7,
fontface   = "bold",
lineheight = 0.9
) +
poverty_fill_scale +
scale_color_identity(guide = "none") +
scale_y_continuous(
limits = c(0, 100),
breaks = seq(0, 100, by = 20),
labels = function(x) paste0(x, "%")
) +
labs(
x = "% of Households Below 100% Federal Poverty Line",
y = "% Wastewater Among Impacted Segments",
title    = main_title,
subtitle = subtitle
) +
theme_ms() +
theme(
axis.text.x     = element_text(angle = 25, hjust = 1),
legend.position = "right"
)
}
library(tidyr)
model_path <- '/Users/kylieboenischoakes/Library/CloudStorage/OneDrive-UCB-O365/General/Boenisch-Oakes, Kylie/Research/Chapter 4/ModelVToolData.xlsx'
# -----------------------------
# 1) Read + tidy RData sheet
# -----------------------------
rdata <- read_excel(model_path, sheet = "RData") %>%
rename(
location    = `Location`,
field_mean  = `%WW Field`,
field_sd    = `%WW Field Sd`,
gage_pctww  = `%WW Gage`,
gage_max    = `Max Gage%`,
gage_min    = `Min Gage %`,
nhd_pctww   = `%WW NHDPlus`
) %>%
mutate(
# always start from character
month_chr = str_trim(as.character(Month)),
# case 1: Excel serials that show up as "45231" or "45231.0"
month_str = case_when(
str_detect(month_chr, "^[0-9]+(\\.[0-9]+)?$") ~
format(as.Date(as.numeric(month_chr), origin = "1899-12-30"), "%b-%y"),
# case 2: true date strings like 1/15/2024 or 2024-01-15
str_detect(month_chr, "^[0-9]{1,2}/[0-9]{1,2}/[0-9]{2,4}$|^[0-9]{4}-[0-9]{2}-[0-9]{2}$") ~
format(lubridate::parse_date_time(month_chr, orders = c("mdy", "ymd")), "%b-%y"),
# case 3: already like "Jan-23" / "January-2023" / etc (leave as-is)
TRUE ~ month_chr
),
# convert fractional columns to percent
across(
c(field_mean, field_sd, gage_pctww, gage_max, gage_min, nhd_pctww),
~ as.numeric(.x) * 100
),
month_idx = match(substr(month_str, 1, 3), month.abb),
site_date = paste0("Site ", location, " – ", month_str)
) %>%
arrange(location, month_idx) %>%
mutate(
site_date   = factor(site_date, levels = unique(site_date)),
location    = factor(location),
field_lower = pmax(0,   field_mean - field_sd),
field_upper = pmin(100, field_mean + field_sd)
)
# -----------------------------
# 2) Long format for tool preds
#    (carry gage min/max for gage only)
# -----------------------------
tool_long <- rdata %>%
select(
site_date,
location,
month_str,      # new character month label
gage_pctww,
gage_min,
gage_max,
nhd_pctww
) %>%
pivot_longer(
cols      = c(gage_pctww, nhd_pctww),
names_to  = "model",
values_to = "tool_pctww"
) %>%
mutate(
model = recode(
model,
gage_pctww = "Tool – gage-based",
nhd_pctww  = "Tool – NHDPlus"
),
# only keep raw min/max for gage-based rows
raw_min = ifelse(model == "Tool – gage-based", gage_min, NA_real_),
raw_max = ifelse(model == "Tool – gage-based", gage_max, NA_real_),
# build lower/upper for gage-based points
gage_lower = dplyr::case_when(
!is.na(raw_min) & !is.na(raw_max) ~ raw_min,       # both given: min
!is.na(raw_min) &  is.na(raw_max) ~ raw_min,       # only min: min → point
is.na(raw_min)  & !is.na(raw_max) ~ tool_pctww,    # only max: point → max
TRUE                                ~ NA_real_
),
gage_upper = dplyr::case_when(
!is.na(raw_min) & !is.na(raw_max) ~ raw_max,       # both given: max
!is.na(raw_min) &  is.na(raw_max) ~ tool_pctww,    # only min: point
is.na(raw_min)  & !is.na(raw_max) ~ raw_max,       # only max: max
TRUE                                ~ NA_real_
),
# for NHD rows: zero-length dummy bar at the point (for dodge alignment)
gage_lower = ifelse(model == "Tool – NHDPlus", tool_pctww, gage_lower),
gage_upper = ifelse(model == "Tool – NHDPlus", tool_pctww, gage_upper)
)
# -----------------------------
# 3) Plot: field bars + tool pts
#    + optional gage min/max bars
# -----------------------------
pd <- position_dodge(width = 0.5)
p_site_date <- ggplot() +
geom_col(
data  = rdata,
aes(x = site_date, y = field_mean),
width  = 0.7,
fill   = "grey75",
colour = "grey40"
) +
geom_errorbar(
data = rdata,
aes(x = site_date, ymin = field_lower, ymax = field_upper),
width  = 0.2,
colour = "black"
) +
geom_errorbar(
data = tool_long,
aes(
x     = site_date,
ymin  = gage_lower,
ymax  = gage_upper,
colour = model,
alpha  = model
),
width    = 0.15,
position = pd
) +
geom_point(
data = tool_long,
aes(
x     = site_date,
y     = tool_pctww,
shape = model,
colour = model
),
size     = 2.7,
position = pd
) +
scale_colour_manual(
values = c(
"Tool – gage-based" = "#1b9e77",
"Tool – NHDPlus"    = "#7570b3"
),
name = NULL
) +
scale_shape_manual(
values = c(
"Tool – gage-based" = 16,
"Tool – NHDPlus"    = 17
),
name = NULL
) +
scale_alpha_manual(
values = c(
"Tool – gage-based" = 1,
"Tool – NHDPlus"    = 0   # hide NHD error bars
),
guide = "none"
) +
scale_y_continuous(
limits = c(0, 100),
breaks = seq(0, 100, 10),
labels = function(x) paste0(x, "%")
) +
labs(
x        = "Site ID and Sample Date",
y        = "% Wastewater in Stream (%WW)",
title    = "Field-Measured vs Tool-Estimated Wastewater Contribution",
subtitle = "Bars = field mean (±1 SD); green points/lines = gage-based; purple points = NHDPlus"
) +
theme_ms() +
theme(
axis.text.x = element_text(
angle = 60, hjust = 1, vjust = 1, size = 7
),
legend.position = "top",
legend.direction = "horizontal"
)
p_site_date
# ============================================================
# 7) Spearman Correlation: Field vs Tool Estimates
# ============================================================
library(broom)
# --- Gage-based ---
gage_cor <- cor.test(
rdata$field_mean,
rdata$gage_pctww,
method = "spearman",
use    = "complete.obs"
)
# --- NHDPlus ---
nhd_cor <- cor.test(
rdata$field_mean,
rdata$nhd_pctww,
method = "spearman",
use    = "complete.obs"
)
# --- Print results ---
cat("=== Spearman Correlation: Field Mean vs. Gage-Based ===\n")
print(gage_cor)
cat("\n=== Spearman Correlation: Field Mean vs. NHDPlus ===\n")
print(nhd_cor)
# --- Tidy summary table ---
cor_summary <- bind_rows(
tidy(gage_cor) %>% mutate(comparison = "Field vs. Gage-based"),
tidy(nhd_cor)  %>% mutate(comparison = "Field vs. NHDPlus")
) %>%
select(comparison, estimate, statistic, p.value) %>%
rename(
rho  = estimate,
S    = statistic,
p    = p.value
) %>%
mutate(across(where(is.numeric), ~ round(.x, 3)))
print(cor_summary)
library(ggplot2)
library(patchwork)
# --- Shared axis limits ---
axis_max <- 100
# --- Helper: build one 1:1 panel ---
make_1to1_plot <- function(df, x_col, y_col, color, shape_val,
x_label, y_label, title_str, rho, p_val) {
# Force intercept through zero
fit       <- lm(df[[y_col]] ~ df[[x_col]] + 0)
slope     <- coef(fit)[1]
r2        <- summary(fit)$r.squared
cor_label <- sprintf("ρ = %.2f\np %s", rho,
ifelse(p_val < 0.001, "< 0.001",
paste0("= ", round(p_val, 3))))
# No intercept term in label
lm_label  <- sprintf("y = %.2fx  (forced 0)\nR² = %.2f", slope, r2)
ggplot(df, aes(x = .data[[x_col]], y = .data[[y_col]])) +
geom_abline(slope = 1, intercept = 0,
linetype = "dashed", colour = "grey50", linewidth = 0.7) +
# forced zero intercept fit line
geom_smooth(method  = "lm",
formula = y ~ x + 0,   # <-- key change
se      = TRUE,
colour   = color,
fill     = color,
alpha    = 0.15,
linewidth = 0.9) +
geom_errorbarh(
aes(xmin = field_lower, xmax = field_upper),
height    = 0,
colour    = "grey40",
linewidth = 0.45,
alpha     = 0.6
) +
geom_point(colour = color, shape = shape_val, size = 2.8, alpha = 0.85) +
annotate("text",
x = 0.02 * axis_max, y = 0.97 * axis_max,
label = cor_label,
hjust = 0, vjust = 1,
size = 3.2, fontface = "italic") +
annotate("text",
x = 0.98 * axis_max, y = 0.05 * axis_max,
label = lm_label,
hjust = 1, vjust = 0,
size = 3.0, fontface = "italic", colour = color) +
scale_x_continuous(limits = c(0, axis_max),
breaks = seq(0, axis_max, 20),
labels = function(x) paste0(x, "%")) +
scale_y_continuous(limits = c(0, axis_max),
breaks = seq(0, axis_max, 20),
labels = function(x) paste0(x, "%")) +
coord_fixed() +
labs(x = x_label, y = y_label, title = title_str) +
theme_ms()
}
# --- Panel A: Gage-based vs Field ---
p_1to1_gage <- make_1to1_plot(
df        = rdata %>% filter(!is.na(field_mean) & !is.na(gage_pctww)),
x_col     = "field_mean",
y_col     = "gage_pctww",
color     = "#1b9e77",
shape_val = 16,
x_label   = "Field-Measured %WW (mean ± 1 SD)",
y_label   = "Tool-Estimated %WW (Gage-based)",
title_str = "A: Gage-based vs. Field",
rho       = gage_cor$estimate,
p_val     = gage_cor$p.value
)
# --- Panel B: NHDPlus vs Field ---
p_1to1_nhd <- make_1to1_plot(
df        = rdata %>% filter(!is.na(field_mean) & !is.na(nhd_pctww)),
x_col     = "field_mean",
y_col     = "nhd_pctww",
color     = "#7570b3",
shape_val = 17,
x_label   = "Field-Measured %WW (mean ± 1 SD)",
y_label   = "Tool-Estimated %WW (NHDPlus)",
title_str = "B: NHDPlus vs. Field",
rho       = nhd_cor$estimate,
p_val     = nhd_cor$p.value
)
# --- Combined panel ---
p_1to1 <- (p_1to1_gage | p_1to1_nhd) +
plot_annotation(
title    = "Field-Measured vs. Tool-Estimated Wastewater Contribution (1:1 plots)",
subtitle = "Horizontal error bars = ±1 SD of field mean; dashed line = 1:1 agreement",
theme    = theme(
plot.title    = element_text(face = "bold", size = 13, hjust = 0.5),
plot.subtitle = element_text(size = 10, hjust = 0.5)
)
)
print(p_1to1)
# --- Helper: build one 1:1 panel ---
make_1to1_plot <- function(df, x_col, y_col, color, shape_val,
x_label, y_label, title_str, rho, p_val) {
# Force intercept through zero
fit       <- lm(df[[y_col]] ~ df[[x_col]] + 0)
slope     <- coef(fit)[1]
r2        <- summary(fit)$r.squared
cor_label <- sprintf("ρ = %.2f\np %s", rho,
ifelse(p_val < 0.001, "< 0.001",
paste0("= ", round(p_val, 3))))
# No intercept term in label
lm_label  <- sprintf("y = %.2fx  (through 0)\nR² = %.2f", slope, r2)
ggplot(df, aes(x = .data[[x_col]], y = .data[[y_col]])) +
geom_abline(slope = 1, intercept = 0,
linetype = "dashed", colour = "grey50", linewidth = 0.7) +
# forced zero intercept fit line
geom_smooth(method  = "lm",
formula = y ~ x + 0,   # <-- key change
se      = TRUE,
colour   = color,
fill     = color,
alpha    = 0.15,
linewidth = 0.9) +
geom_errorbarh(
aes(xmin = field_lower, xmax = field_upper),
height    = 0,
colour    = "grey40",
linewidth = 0.45,
alpha     = 0.6
) +
geom_point(colour = color, shape = shape_val, size = 2.8, alpha = 0.85) +
annotate("text",
x = 0.02 * axis_max, y = 0.97 * axis_max,
label = cor_label,
hjust = 0, vjust = 1,
size = 3.2, fontface = "italic") +
annotate("text",
x = 0.98 * axis_max, y = 0.05 * axis_max,
label = lm_label,
hjust = 1, vjust = 0,
size = 3.0, fontface = "italic", colour = color) +
scale_x_continuous(limits = c(0, axis_max),
breaks = seq(0, axis_max, 20),
labels = function(x) paste0(x, "%")) +
scale_y_continuous(limits = c(0, axis_max),
breaks = seq(0, axis_max, 20),
labels = function(x) paste0(x, "%")) +
coord_fixed() +
labs(x = x_label, y = y_label, title = title_str) +
theme_ms()
}
# --- Panel A: Gage-based vs Field ---
p_1to1_gage <- make_1to1_plot(
df        = rdata %>% filter(!is.na(field_mean) & !is.na(gage_pctww)),
x_col     = "field_mean",
y_col     = "gage_pctww",
color     = "#1b9e77",
shape_val = 16,
x_label   = "Field-Measured %WW (mean ± 1 SD)",
y_label   = "Tool-Estimated %WW (Gage-based)",
title_str = "A: Gage-based vs. Field",
rho       = gage_cor$estimate,
p_val     = gage_cor$p.value
)
# --- Panel B: NHDPlus vs Field ---
p_1to1_nhd <- make_1to1_plot(
df        = rdata %>% filter(!is.na(field_mean) & !is.na(nhd_pctww)),
x_col     = "field_mean",
y_col     = "nhd_pctww",
color     = "#7570b3",
shape_val = 17,
x_label   = "Field-Measured %WW (mean ± 1 SD)",
y_label   = "Tool-Estimated %WW (NHDPlus)",
title_str = "B: NHDPlus vs. Field",
rho       = nhd_cor$estimate,
p_val     = nhd_cor$p.value
)
# --- Combined panel ---
p_1to1 <- (p_1to1_gage | p_1to1_nhd) +
plot_annotation(
title    = "Field-Measured vs. Tool-Estimated Wastewater Contribution (1:1 plots)",
subtitle = "Horizontal error bars = ±1 SD of field mean; dashed line = 1:1 agreement",
theme    = theme(
plot.title    = element_text(face = "bold", size = 13, hjust = 0.5),
plot.subtitle = element_text(size = 10, hjust = 0.5)
)
)
print(p_1to1)
