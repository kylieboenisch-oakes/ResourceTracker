panel.grid.major   = element_line(colour = "grey92", linewidth = 0.35),
panel.grid.major.x = element_line(colour = "grey92", linewidth = 0.35),
panel.grid.minor   = element_blank(),
plot.title         = element_text(size = 11, face = "bold", hjust = 0.5),
plot.margin        = margin(8, 12, 8, 8)
)
}
p_labeled_gage <- make_1to1_labeled(
df        = rdata %>% filter(!is.na(field_mean) & !is.na(gage_pctww)),
x_col     = "field_mean",
y_col     = "gage_pctww",
color     = "#1b9e77",
shape_val = 16,
x_label   = "Field-Measured %WW (mean ± 1 SD)",
y_label   = "Tool-Estimated %WW (Gage-based)",
title_str = "Gage-based vs. Field",
rho       = gage_cor$estimate,
p_val     = gage_cor$p.value
)
p_labeled_nhd <- make_1to1_labeled(
df        = rdata %>% filter(!is.na(field_mean) & !is.na(nhd_pctww)),
x_col     = "field_mean",
y_col     = "nhd_pctww",
color     = "#7570b3",
shape_val = 17,
x_label   = "Field-Measured %WW (mean ± 1 SD)",
y_label   = "Tool-Estimated %WW (NHDPlus)",
title_str = "NHDPlus vs. Field",
rho       = nhd_cor$estimate,
p_val     = nhd_cor$p.value
)
p_labeled <- (p_labeled_gage | p_labeled_nhd) +
plot_annotation(
title    = "Field vs. Tool Estimates — Site-Level Bias Diagnostics",
subtitle = "Point color = bias (orange = overestimate, purple = underestimate)  |  Dashed = 1:1",
theme    = theme(
plot.title    = element_text(face = "bold", size = 13, hjust = 0.5),
plot.subtitle = element_text(size = 9, hjust = 0.5, colour = "grey40")
)
) &
theme(plot.background = element_rect(fill = "white", colour = NA))
print(p_labeled)
rdata_no4 <- rdata %>% filter(location != "4")
# --- Recompute correlations without site 4 ---
gage_cor_no4 <- cor.test(
rdata_no4$field_mean,
rdata_no4$gage_pctww,
method = "spearman",
use    = "complete.obs"
)
nhd_cor_no4 <- cor.test(
rdata_no4$field_mean,
rdata_no4$nhd_pctww,
method = "spearman",
use    = "complete.obs"
)
# --- Print comparison ---
cat("=== Sensitivity: Gage-based WITH Site 4 ===\n")
cat(sprintf("  ρ = %.3f, p = %.4f\n", gage_cor$estimate, gage_cor$p.value))
cat("=== Sensitivity: Gage-based WITHOUT Site 4 ===\n")
cat(sprintf("  ρ = %.3f, p = %.4f\n\n", gage_cor_no4$estimate, gage_cor_no4$p.value))
cat("=== Sensitivity: NHDPlus WITH Site 4 ===\n")
cat(sprintf("  ρ = %.3f, p = %.4f\n", nhd_cor$estimate, nhd_cor$p.value))
cat("=== Sensitivity: NHDPlus WITHOUT Site 4 ===\n")
cat(sprintf("  ρ = %.3f, p = %.4f\n", nhd_cor_no4$estimate, nhd_cor_no4$p.value))
# --- 1:1 plots without site 4 ---
p_1to1_gage_no4 <- make_1to1_plot(
df        = rdata_no4 %>% filter(!is.na(field_mean) & !is.na(gage_pctww)),
x_col     = "field_mean",
y_col     = "gage_pctww",
color     = "#1b9e77",
shape_val = 16,
x_label   = "Field-Measured %WW (mean ± 1 SD)",
y_label   = "Tool-Estimated %WW (Gage-based)",
title_str = "A: Gage-based vs. Field (Site 4 removed)",
rho       = gage_cor_no4$estimate,
p_val     = gage_cor_no4$p.value
)
p_1to1_nhd_no4 <- make_1to1_plot(
df        = rdata_no4 %>% filter(!is.na(field_mean) & !is.na(nhd_pctww)),
x_col     = "field_mean",
y_col     = "nhd_pctww",
color     = "#7570b3",
shape_val = 17,
x_label   = "Field-Measured %WW (mean ± 1 SD)",
y_label   = "Tool-Estimated %WW (NHDPlus)",
title_str = "B: NHDPlus vs. Field (Site 4 removed)",
rho       = nhd_cor_no4$estimate,
p_val     = nhd_cor_no4$p.value
)
# --- Side by side: original vs no-site-4 for easy comparison ---
(p_1to1_gage | p_1to1_gage_no4) /
(p_1to1_nhd  | p_1to1_nhd_no4) +
plot_annotation(
title    = "Sensitivity Check: With vs. Without Site 4",
subtitle = "Left = all sites; Right = Site 4 removed",
theme    = theme(
plot.title    = element_text(face = "bold", size = 13, hjust = 0.5),
plot.subtitle = element_text(size = 10, hjust = 0.5, colour = "grey40")
)
)
# --- Libraries ---------------------------------------------------------------
library(tidyverse)
library(readxl)
library(readr)
library(sf)
library(tigris)
library(viridisLite)
options(tigris_use_cache = TRUE)
# --- Base paths --------------------------------------------------------------
data_dir <- "data-raw"
paths <- list(
dwtp          = file.path(data_dir, "filtereddwtpCOFinal.csv"),
cejst         = file.path(data_dir, "ColoradoCEJSTData.xlsx"),
matched_dmr   = file.path(data_dir, "matchedDMRwwtpupdated6.csv"),
wwtp          = file.path(data_dir, "PermittedPOTW.xlsx"),
flowlines     = file.path(data_dir, "Flowlines_Colorado_Filtered.gpkg"),
monthly_flows = file.path(data_dir, "CO_Seasonal_Flow_Summary_Feb2026.csv"),
gages_sf      = file.path(data_dir, "processed_gages_sf_combinedV4.gpkg"),
ur10          = file.path(data_dir, "CO_2010_URBANRURAL_TRACTS.csv")
)
check_required_file <- function(path, label, url = NULL) {
if (!file.exists(path)) {
msg <- paste0(
"Missing required data file: ", label, "\n",
"Expected at:\n  ", normalizePath(path, winslash = "/", mustWork = FALSE), "\n\n"
)
if (!is.null(url)) {
msg <- paste0(
msg,
"Download it from:\n  ", url, "\n\n",
"Save it at the path above and then rerun the script.\n"
)
}
stop(msg, call. = FALSE)
}
}
safe_round <- function(x) ifelse(is.finite(x), round(x, 1), "NA")
# Simple % helper
compute_pct <- function(ww, denom) {
ifelse(
is.na(denom) | is.na(ww) | denom <= 0,
NA_real_,
pmin(100, pmax(0, 100 * ww / denom))
)
}
# --- Required file checks ----------------------------------------------------
check_required_file(
paths$flowlines,
"Flowlines_Colorado_Filtered.gpkg",
"https://github.com/sheldonmasters/Masters-Research-Group/releases/tag/v0.1.0"
)
